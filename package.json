{
  "name": "ai-skills-hub",
  "version": "0.2.0",
  "description": "Interface modulaire de skills IA pour agents (TypeScript)",
  "type": "module",
  "scripts": {
    "build:client": "esbuild src/client/app.ts --bundle --outfile=public/app.js --target=es2020 --format=iife --sourcemap",
    "watch:client": "esbuild src/client/app.ts --bundle --outfile=public/app.js --target=es2020 --format=iife --sourcemap --watch",
    "start": "npm run build:client && tsx src/server.ts",
    "dev": "npm run build:client && concurrently -k -n server,client -c blue,magenta \"tsx watch src/server.ts\" \"npm:watch:client\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
